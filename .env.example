# TokenTriage environment configuration
# Copy to .env and fill in. NEVER commit real keys (rubric hard rule).
# .env is gitignored; this .example file is the committed template.

# --- Phase 1: fully local, NO keys needed --------------------------------
# Tiers run on local open-source models via Ollama (see models/registry.py).
# Just have Ollama running with the models pulled (one per command):
#   ollama pull qwen2.5:3b
#   ollama pull qwen2.5:7b
#   ollama pull qwen2.5:14b
#   ollama pull nomic-embed-text
OLLAMA_HOST=http://localhost:11434
TOKENTRIAGE_EMBED_PROVIDER=ollama            # local embeddings for the T0 cache
TOKENTRIAGE_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- OpenRouter cloud rescue ---------------------------------------------
# We rely on OpenRouter for cloud/provider diversity. One fallback key can
# power every OpenRouter tier. Per-tier keys below override it (isolation).
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=TokenTriage

# Model-specific OpenRouter key isolation. OpenRouter keys are account/project
# keys, not truly model keys, but separate keys let us isolate usage by model.
# If blank, each model falls back to OPENROUTER_API_KEY.
TOKENTRIAGE_OR_GEMMA_31B_KEY=
TOKENTRIAGE_OR_GPT_OSS_20B_KEY=
TOKENTRIAGE_OR_QWEN_NEXT_80B_KEY=
TOKENTRIAGE_OR_QWEN_CODER_480B_KEY=
TOKENTRIAGE_OR_NEMOTRON_SAFETY_KEY=
TOKENTRIAGE_OR_NEMOTRON_VL_KEY=

# Future cloud tiers, if you move T1/T2/T3 from Ollama to OpenRouter later.
TOKENTRIAGE_T1_API_KEY=
TOKENTRIAGE_T2_API_KEY=
TOKENTRIAGE_T3_API_KEY=

# Note: If a cloud tier is configured but its key is missing, the orchestrator
# disables it and safely falls back to available local tiers.
# The Gemini-compatible ingress remains available even without a Gemini key:
#   POST /v1beta/models/{model}:generateContent

# --- Server ---------------------------------------------------------------
TOKENTRIAGE_HOST=0.0.0.0
TOKENTRIAGE_PORT=8000

# --- Storage --------------------------------------------------------------
TOKENTRIAGE_DB_PATH=tokentriage.db

# --- Policy ---------------------------------------------------------------
TOKENTRIAGE_POLICY_PATH=config/policy.yaml
