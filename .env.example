# TokenTriage environment configuration
# Copy to .env and fill in. NEVER commit real keys (rubric hard rule).

# --- Per-tier key isolation ---------------------------------------------
# Each tier reads its OWN variable. In the simplest setup all three can be
# the same Gemini key, but isolation means a leaked cheap-tier key cannot
# be used to call the expensive tier if you provision separate keys.
TOKENTRIAGE_T1_API_KEY=your-gemini-key-for-flash-lite
TOKENTRIAGE_T2_API_KEY=your-gemini-key-for-flash
TOKENTRIAGE_T3_API_KEY=your-gemini-key-for-pro

# Embeddings for the semantic cache (tier 0)
TOKENTRIAGE_EMBED_API_KEY=your-gemini-key-for-embeddings

# --- Server ---------------------------------------------------------------
TOKENTRIAGE_HOST=0.0.0.0
TOKENTRIAGE_PORT=8000

# --- Storage ---------------------------------------------------------------
TOKENTRIAGE_DB_PATH=tokentriage.db

# --- Policy ---------------------------------------------------------------
TOKENTRIAGE_POLICY_PATH=config/policy.yaml
