# TokenTriage environment configuration
# Copy this file to .env and fill values locally.
# NEVER commit real API keys. .env is gitignored.

# --- Local Ollama runtime -------------------------------------------------
# Full local demo path. Keep Ollama running and pull:
#   ollama pull qwen2.5:3b
#   ollama pull qwen2.5:7b
#   ollama pull qwen2.5:14b
#   ollama pull nomic-embed-text
OLLAMA_HOST=http://localhost:11434
TOKENTRIAGE_EMBED_PROVIDER=ollama
TOKENTRIAGE_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Optional OpenRouter rescue ------------------------------------------
# Cloud dispatch is disabled by default even if keys are present.
# Set TOKENTRIAGE_ENABLE_CLOUD=1 or pass --allow-cloud to opt in.
TOKENTRIAGE_ENABLE_CLOUD=0

# Leave blank for zero OpenRouter/cloud calls. When cloud is enabled, one
# OpenRouter API key switches among the configured OpenRouter rescue tiers.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=TokenTriage

# --- Server ---------------------------------------------------------------
TOKENTRIAGE_HOST=0.0.0.0
TOKENTRIAGE_PORT=8000

# --- Storage --------------------------------------------------------------
# Persist this file/volume in hosted judge replay deployments.
TOKENTRIAGE_DB_PATH=tokentriage.db

# --- Policy ---------------------------------------------------------------
TOKENTRIAGE_POLICY_PATH=config/policy.yaml
